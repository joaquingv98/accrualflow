# Copy to .env and fill in locally (never commit .env).
OPENAI_API_KEY=
# Optional API port (default 8787)
# OCR_API_PORT=8787
# Frontend: URL base de la API desplegada (Netlify / prod). Sin barra final.
# VITE_API_URL=https://tu-api.onrender.com
#
# API (Render, etc.): CORS extra además de localhost y *.netlify.app
# CORS_ORIGINS=https://tu-dominio.com

# Emparejamiento de facturas/devengos/solicitudes (opcional)
# MATCH_SCORE_HIGH=70
# MATCH_SCORE_MEDIUM=40
# MATCH_AMOUNT_REL_TOLERANCE=0.08
# MATCH_AMOUNT_ABS_MIN=50
# Comparar importes de factura: total (defecto) o base imponible
# INVOICE_MATCH_AMOUNT_FIELD=total
